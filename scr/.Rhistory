#### Now hDMV_hg19 based on Bing Ren's 2013 paper
pc_neg_dmv_hg19 <- read.table("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/Public_methylation_datasets/Human/DMVs_Ren_2013/Polycomb/hDMV_pc_inactive_hg19_050724.bed")
pc_pos_dmv_hg19 <- read.table("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/Public_methylation_datasets/Human/DMVs_Ren_2013/Polycomb/hDMV_pc_pos_hg19_sorted_050724.bed")
