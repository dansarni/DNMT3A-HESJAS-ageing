library(minfi)
library(minfiData)
library(IlluminaHumanMethylationEPICmanifest)
#library(IlluminaHumanMethylationEPICanno.ilm10b4.hg19)
library(IlluminaHumanMethylationEPICanno.ilm10b5.hg38) # to be used when we are ready for hg38
library(FlowSorted.Blood.EPIC)
library(factoextra)
library(tibble)
library(RColorBrewer)
library(tidyverse)
library(eulerr)
# 2.1 Set up WD
setwd("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/R/EPIC/EPIC/Validation")
# 2.2 Upload files
# upload the sample sheet .csv file
targets.APJ <- read.csv("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/R/EPIC/EPIC/Validation/PGL/Targets_NO_PGL_all_mutants_only_ours.csv")
# use 'read.metharray.exp' to read the .idat data files
RGset.APJ <- read.metharray.exp(targets = targets.APJ, force = T)
# To be used when we are ready for hg38
RGset.APJ@annotation = c(array = "IlluminaHumanMethylationEPIC", annotation = "ilm10b5.hg38")
# 3.1 Phenotype data information
phenoData.APJ <- pData(RGset.APJ)
# 3.2 Probe design information
manifest.APJ <- getManifest(RGset.APJ)
head(getProbeInfo(manifest.APJ))
# 4.1 Create a Methylset object
Mset.APJ <- preprocessRaw(RGset.APJ)
# 4.2 Create an RatioSet object, containing Beta values (and M values)
Rset.APJ <- ratioConvert(Mset.APJ, what = "both", keepCN = T)
# Extract the beta, M and CN values
beta.APJ <- getBeta(Rset.APJ)
M.APJ <- getM(Rset.APJ)
CN.APJ <- getCN(Rset.APJ)
# 5.1 Rset.APJ
GenoRset.APJ <- mapToGenome(Rset.APJ, mergeManifest = T)
# Extract the beta, M and CN values
G.beta.APJ <- getBeta(GenoRset.APJ) # Get genomic Beta values from 'GenoRset.APJ'
G.M.APJ <- getM(GenoRset.APJ) # Get genomic M values from 'GenoRset.APJ'
G.CN.APJ <- getCN(GenoRset.APJ) # Get genomic CN values from 'GenoRset.APJ'
# 5.2 Mset.APJ
GenoMset.APJ <- mapToGenome(Mset.APJ, mergeManifest = T)
# Extract the beta, M and CN values
G.M.beta.APJ <- getBeta(GenoMset.APJ) # Get genomic beta values from 'GenoMset.APJ'
G.M.M.APJ <- getM(GenoMset.APJ) # Get genomic M values from 'GenoMset.APJ'
G.M.CN.APJ <- getCN(GenoMset.APJ) # Get genomic CN values from 'GenoMset.APJ'
# 5.3
sampleNames.APJ <- sampleNames(GenoRset.APJ)
probeNames.APJ <- featureNames(GenoRset.APJ)
pheno.APJ <- pData(GenoRset.APJ)
# Probe locations as a GenomicRanges object
probe.gr.APJ <- granges(GenoRset.APJ)
annotation.APJ <- getAnnotation(GenoRset.APJ)
qc.APJ <- getQC(Mset.APJ)
plotQC(qc.APJ)
densityPlot(Mset.APJ, sampGroups = phenoData.APJ$Sample_Group)
densityBeanPlot(Mset.APJ, sampGroups = phenoData.APJ$Sample_Group,
main="BEta values violin plot - not normalized")
# Control probes plot
controlStripPlot(RGset.APJ, controls = "BISULFITE CONVERSION II")
# 7.1 PreprocessNoob (suggested by Duncan)
Mset.APJ.noob <- preprocessNoob(RGset.APJ)
beta.noob.norm.APJ <- data.frame(getBeta(Mset.APJ.noob))
M.noob.norm.APJ <- getM(Mset.APJ.noob)
CN.noob.norm.APJ <- getCN(Mset.APJ.noob)
# QC the normalized data - use Noob as suggested by Duncan
Mset.APJ.noob.qc <- minfiQC(Mset.APJ.noob)
# Set column names to samples
colnames(beta.noob.norm.APJ) <- sub(" ", "_", RGset.APJ$Sample_Name)
# Remove non-CG probes and re-order
beta.noob.norm.APJ <- beta.noob.norm.APJ[grep("^cg", rownames(beta.noob.norm.APJ)),]
beta.noob.norm.APJ <- beta.noob.norm.APJ[order(rownames(beta.noob.norm.APJ)),]
# 7.1 PreprocessNoob (suggested by Duncan)
Mset.APJ.noob <- preprocessNoob(RGset.APJ)
beta.noob.norm.APJ <- data.frame(getBeta(Mset.APJ.noob))
M.noob.norm.APJ <- getM(Mset.APJ.noob)
CN.noob.norm.APJ <- getCN(Mset.APJ.noob)
# QC the normalized data - use Noob as suggested by Duncan
Mset.APJ.noob.qc <- minfiQC(Mset.APJ.noob)
# Set column names to samples
colnames(beta.noob.norm.APJ) <- sub(" ", "_", RGset.APJ$Sample_Name)
# Remove non-CG probes and re-order
beta.noob.norm.APJ <- beta.noob.norm.APJ[grep("^cg", rownames(beta.noob.norm.APJ)),]
beta.noob.norm.APJ <- beta.noob.norm.APJ[order(rownames(beta.noob.norm.APJ)),]
# Density plot normalized and processed data
densityBeanPlot(as.matrix(beta.noob.norm.APJ),
sampGroups = phenoData.APJ$Sample_Group,
main="Beta values Violin Plot - Noob Norm")
df <- read.table("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/Manuscript/Analyses/Human/EPIC/Files/EPIC_DNMT3A_beta_hg19_hg38_220724.tsv", sep = '\t')
# Detect p-values
RGset.APJ.pval <- detectionP(RGset.APJ, type = "m+u")
View(df)
df <- read.table("U:/Datastore/IGMM/ajackson-wrkgrp/People/Dan/DNMT3A_Project/Manuscript/Analyses/Human/EPIC/Files/EPIC_DNMT3A_beta_hg19_hg38_220724.tsv", sep = '\t', header = T)
cat("The number of rows in RGset.APJ is", nrow(RGset.APJ))
cat("The number of rows in RGset.APJ.pval is", nrow(RGset.APJ.pval))
cat("The number of rows in beta.noob.norm.APJ is", nrow(beta.noob.norm.APJ))
beta.noob.pval.APJ <- merge(beta.noob.norm.APJ, RGset.APJ.pval, by = 'row.names', all = T)
beta.noob.pval.APJ <- beta.noob.pval.APJ[!is.na(beta.noob.pval.APJ$C3),] # remove rows corresponding to non-CG probes
cat("The number of rows in beta.noob.pval.APJ is", nrow(beta.noob.pval.APJ))
colnames(beta.noob.pval.APJ)[18:33] <- paste(colnames(beta.noob.pval.APJ)[2:17],".pval", sep="")
# Replace p.val > 0.01 with NA
beta.noob.pval.APJ.detec <- beta.noob.pval.APJ
beta.noob.pval.APJ.detec[,c(18:33)][beta.noob.pval.APJ.detec[,c(18:33)] > 0.01] <- NA
# Remove non-autosomal probes and SNPs
manifest_hg38 <- read.table("U:/Datastore/IGMM/ajackson-epigen/Dnmt3a_EPIC_March_2023 working copy/Analysis/Files/EPIC.hg38.manifest.tsv.gz", header = T)
probe.loc <- manifest_hg38[,c(1:3,9)]
# probe.loc <- read.table("U:/Datastore/IGMM/ajackson-epigen/infinium_files_heyn_2019_020523/Annotations_270917/Clare_DNMT3A_EPIC_probe_loc_hg37_220417.bed",
#                         sep="\t", header=FALSE, stringsAsFactors=FALSE, col.names=c("chr","start","end","probe.id"))
# Get a list of chromosome X and Y probes
cpg.list.chrXY <- probe.loc$probe.id[probe.loc$chr=="chrX" | probe.loc$chr=="chrY"]
# Read in the zhou probe annotation
zhou.probe.annot <- read.table("U:/Datastore/IGMM/ajackson-epigen/infinium_files_heyn_2019_020523/Annotations_270917/EPIC.anno.GRCh38.tsv.gz",
sep="\t", header=TRUE, stringsAsFactors=FALSE)
# Get list of SNP probes from Zhou annotation
cpg.list.snp <- zhou.probe.annot$probeID[zhou.probe.annot$MASK.snp5.GMAF1p==TRUE]
# Create a list of probes to exclude
probe.list.to.excl <- unique(c(cpg.list.chrXY, cpg.list.snp))
# Exclude the above probes from the beta.value data
beta.noob.norm.APJ.excl <- beta.noob.pval.APJ.detec[!(beta.noob.pval.APJ.detec$Row.names %in% probe.list.to.excl),]
# Tidy up, remove unnecessary tables
rm(zhou.probe.annot, cpg.list.chrXY, cpg.list.snp)
cat("The number of rows in beta.noob.pval.APJ.detec is", nrow(beta.noob.pval.APJ.detec))
cat("The number of rows in beta.noob.roem.APJ.excl is", nrow(beta.noob.norm.APJ.excl))
for(i in 1:16){
tmp.na.lst <- rownames(beta.noob.norm.APJ.excl[is.na(beta.noob.norm.APJ.excl[,(17+i)]),])
beta.noob.norm.APJ.excl[tmp.na.lst,(i+1)] <- NA
}
# Dendrogram, use non-filtered beta values
beta.dist.APJ <- dist(t(beta.noob.norm.APJ), method = "euclidean")
beta.clusters.APJ <- hclust(beta.dist.APJ, method = "average")
beta.dist.up.dmr <- beta.noob.norm.APJ[row.names(beta.noob.norm.APJ) %in% blood.dmr.probe.up$probe.id ,]
# PCA
beta.pca <- prcomp(t(beta.noob.norm.APJ), scale.=F, retx=T)
ls(beta.pca)
summary(beta.pca)
beta.pca.df <- as_tibble(beta.pca$x)
beta.pc.var<-beta.pca$sdev^2
beta.pc.per<-round(beta.pc.var/sum(beta.pc.var)*100, 1)
ggplot(beta.pca.df) +
aes(x=PC1, y=PC2, label=RGset.APJ$Sample_Name, color = RGset.APJ$Sample_Group) +
geom_point(size=2) +
scale_color_manual(values=c("#385BE6", "#FF6666"))+
xlab(paste0("PC1 (",beta.pc.per[1],"%",")")) +
ylab(paste0("PC2 (",beta.pc.per[2],"%",")")) +
labs(title="PCA plot") +
geom_text(label = RGset.APJ$Sample_Name, nudge_x = 2.5, nudge_y = 2.5, cex = 3)+
coord_fixed() +
theme_bw()
# Create a PCA 'small multiples' chart
beta.pca.df <- beta.pca$x %>%
as_tibble() %>%
add_column(sample = RGset.APJ$Sample_Name,
group = RGset.APJ$Sample_Group)
pca.pivot <- pivot_longer(beta.pca.df,
cols = PC1:PC6,
names_to = "PC",
values_to = "loadings")
ggplot(pca.pivot) +
aes(x=sample, y=loadings, fill=group) +
geom_bar(stat="identity") +
scale_fill_manual(values=c("#385BE6", "#FF6666"))+
facet_wrap(~PC) +
labs(title="PCA 'small multiples' plot") +
theme_bw() +
coord_flip()
# Upload DNMT3A_Dwarf_Fib_DMR_CpG_map_up/down files generated by Duncan
dmr.cpg.map.up <- read.table("U:/Datastore/IGMM/ajackson-epigen/infinium_files_heyn_2019_020523/output_files_DMRs_030718/DNMT3A_Dwarf_Fib_Up_DMR_CpG_map_070318.txt",
sep = "\t", header=TRUE, stringsAsFactors=FALSE, col.names=c("probe.id","dmr.id"))
dmr.cpg.map.down <- read.table("U:/Datastore/IGMM/ajackson-epigen/infinium_files_heyn_2019_020523/output_files_DMRs_030718/DNMT3A_Dwarf_Fib_Down_DMR_CpG_map_070318.txt",
sep = "\t", header=TRUE, stringsAsFactors=FALSE, col.names=c("probe.id","dmr.id"))
# Rename the beta values matrix beta.data
beta.data <- beta.noob.norm.APJ.excl
samples.group.names <- paste(targets.APJ$Sample_Name,targets.APJ$Sample_Group, sep=".")
colnames(beta.data)[2:24] <- samples.group.names
# Sort the data tables in the same order as the DMR map
data.up.dmr.probes <- beta.data[beta.data$Row.names %in% dmr.cpg.map.up$probe.id,]
rownames(data.up.dmr.probes) <- data.up.dmr.probes$Row.names
data.up.dmr.probes <- data.up.dmr.probes[,-1]
data.up.dmr.probes <- data.up.dmr.probes[order(rownames(data.up.dmr.probes)),]
dmr.cpg.map.up.sort <- dmr.cpg.map.up[dmr.cpg.map.up$probe.id %in% row.names(data.up.dmr.probes),]
dmr.cpg.map.up.sort <- dmr.cpg.map.up[order(dmr.cpg.map.up.sort$probe.id),]
data.down.dmr.probes <- beta.data[beta.data$Row.names %in% dmr.cpg.map.down$probe.id,]
rownames(data.down.dmr.probes) <- data.down.dmr.probes$Row.names
data.down.dmr.probes <- data.down.dmr.probes[,-1]
data.down.dmr.probes <- data.down.dmr.probes[order(rownames(data.down.dmr.probes)),]
dmr.cpg.map.down.sort <- dmr.cpg.map.down[dmr.cpg.map.down$probe.id %in% row.names(data.down.dmr.probes),]
dmr.cpg.map.down.sort <- dmr.cpg.map.down[order(dmr.cpg.map.down.sort$probe.id),]
# Compute the mean for each DMR
data.up.dmr <- data.frame(apply(data.up.dmr.probes, 2, function(x, y=dmr.cpg.map.up.sort$dmr.id) {tapply(x, y, mean, na.rm=TRUE);} ))
data.down.dmr <- data.frame(apply(data.down.dmr.probes, 2, function(x, y=dmr.cpg.map.down.sort$dmr.id) {tapply(x, y, mean, na.rm=TRUE);} ))
# Create relative tables to make plots
data.up.dmr.rel.meth.APJ.blood <- data.up.dmr[,1:23] - apply(data.up.dmr[,c(1:11)], 1, mean, na.rm=TRUE)
data.down.dmr.rel.meth.APJ.blood <- data.down.dmr[,1:23] - apply(data.down.dmr[,c(1:11)], 1, mean, na.rm=TRUE)
data.up.dmr.ctrl.mean.blood <- apply(data.up.dmr[,c(1:11)], 1, mean, na.rm=TRUE)
data.down.dmr.ctrl.mean.blood <- apply(data.down.dmr[,c(1:11)], 1, mean, na.rm=TRUE)
# reorder columns by group
data.up.dmr <- data.up.dmr[,c(1:14,17,21,18,19,22,16,15,20,23)]
data.down.dmr <- data.down.dmr[,c(1:14,17,21,18,19,22,16,15,20,23)]
image(x=c(1:ncol(data.up.dmr[,1:23])),y=c(1:nrow(data.up.dmr)),
z=t(data.up.dmr[order(data.up.dmr.ctrl.mean.blood), 1:23]),
col=rev(brewer.pal(10,"RdYlBu")),breaks=seq(0,1,by=0.1),
axes=FALSE,xlab="",ylab="CpGs ordered by mean WT meth",
main="Heatmap DNMT3A EPIC - blood samples in fib DMRs")
# sub = "DMRs are from 3A Dwarf fibroblasts Up DMRs from Patty's work")
box()
mtext(colnames(data.up.dmr[,1:23]), line=0.5, side=1, at=c(1:23),
cex=0.6, las=2)
image(x=c(1:ncol(data.down.dmr[,1:23])),y=c(1:nrow(data.down.dmr)),
z=t(data.down.dmr[order(data.down.dmr.ctrl.mean.blood), 1:23]),
col=rev(brewer.pal(10,"RdYlBu")),breaks=seq(0,1,by=0.1),
axes=FALSE,xlab="",ylab="CpGs ordered by mean WT meth",
main="Heatmap DNMT3A EPIC - blood samples in down fib DMRs")
#sub = "DMRs are from 3A Dwarf fibroblasts down DMRs from Patty's work")
box()
mtext(colnames(data.down.dmr[,1:23]), line=0.5, side=1, at=c(1:23),
cex=0.6, las=2)
# Get ranges of data for plots
data.range.boxplot.up.dmr.blood <- range(data.up.dmr.rel.meth.APJ.blood)
data.range.boxplot.down.dmr.blood <- range(data.down.dmr.rel.meth.APJ.blood)
# reorder data.up.dmr.rel.meth.APJ.blood
data.up.dmr.rel.meth.APJ.blood <- data.up.dmr.rel.meth.APJ.blood[,c(1:14,17,21,18,19,22,16,15,20,23)]
boxplot(data.up.dmr.rel.meth.APJ.blood[,1:23],
names=rep("", times=23), range=0, ylim=data.range.boxplot.up.dmr.blood, col = c(rep("#4169C4",11),rep("#FF6666",12)),
ylab="Beta Value", cex.main=1, main="Boxplot EPIC - blood samples in up fib DMRs")
mtext(colnames(data.up.dmr.rel.meth.APJ.blood)[1:23], line=0.5, side=1, at=c(1:23),
cex=0.6, las=2)
abline(h=0, col="grey", lty = 2)
# reorder data.down.dmr.rel.meth.APJ.blood
data.down.dmr.rel.meth.APJ.blood <- data.down.dmr.rel.meth.APJ.blood[,c(1:14,17,21,18,19,22,16,15,20,23)]
boxplot(data.down.dmr.rel.meth.APJ.blood[,1:23],
names=rep("", times=23), range=0, ylim=data.range.boxplot.down.dmr.blood, col = c(rep("#4169C4",11),rep("#FF6666",12)),
ylab="Beta Value", cex.main=1, main="Boxplot EPIC - blood samples in down fib DMRs")
mtext(colnames(data.down.dmr.rel.meth.APJ.blood)[1:23], line=0.5, side=1, at=c(1:23),
cex=0.6, las=2)
abline(h=0, col="grey", lty = 2)
