pc_pos_dmv_hg19$index <- paste0("DMV_pos_", row.names(pc_pos_dmv_hg19))
# Based on the annotation.APJ matrix, get cg index for each DMR based on the the genomic position
# colnames(annotation.APJ)
# chr - 1
# position - 2
# name - 4
#blood.dmr.combined <- rbind(blood.up.dmr[,1:19], blood.down.dmr)
blood.dmr.combined <- rbind(blood.up.dmr, blood.down.dmr)
blood.dmr.combined <- blood.up.dmr
blood.dmr.anno <- annotation.APJ
for(i in seq_along(blood.dmr.anno[,1])){
tmp <- subset(blood.dmr.combined, V1 == blood.dmr.anno[i,1] &
V2 <= blood.dmr.anno[i,2] &
V3 >= blood.dmr.anno[i,2])
if(length(tmp[,1]) == 0){
next()
} else {
blood.dmr.anno[i,52] <- tmp[1,4] #15
}
}
